<Application
    x:Class="HardwareMonitorWinUI3.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Styles personnalisés pour l'application -->
            
            <!-- Style simple pour tous les boutons de vitesse -->
            <Style x:Key="SpeedButtonStyle" TargetType="Button">
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="MinWidth" Value="80"/>
                <Setter Property="Background" Value="{ThemeResource ButtonBackground}"/>
                <Setter Property="Foreground" Value="{ThemeResource ButtonForeground}"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
            </Style>
            
            <!-- Style pour les boutons de vitesse actifs -->
            <Style x:Key="SpeedButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource SpeedButtonStyle}">
                <Setter Property="BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}"/>
            </Style>
            
            <!-- Style pour les boutons de vitesse inactifs -->
            <Style x:Key="SpeedButtonInactiveStyle" TargetType="Button" BasedOn="{StaticResource SpeedButtonStyle}">
                <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
            </Style>
            <!-- Style pour les cartes de statut -->
            <Style x:Key="StatusCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="20"/>
            </Style>
            
            <!-- Style pour les cartes hardware -->
            <Style x:Key="HardwareCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Margin" Value="0,0,0,12"/>
            </Style>
            
            <!-- Style moderne pour les cartes capteurs - WinUI 3 Gallery -->
            <Style x:Key="SensorCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="MinWidth" Value="260"/>
                <Setter Property="MinHeight" Value="80"/>
                <Setter Property="Margin" Value="4"/>
            </Style>

            <!-- Style pour les groupes de capteurs -->
            <Style x:Key="SensorGroupStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>

            <!-- Other app resources here -->
        </ResourceDictionary>
    </Application.Resources>
</Application> 